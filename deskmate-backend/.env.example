# .env.example
# Salin file ini: cp .env.example .env
# Lalu isi dengan nilai yang sebenarnya.
# JANGAN pernah commit file .env ke Git!

# --- Aplikasi ---
DEBUG=True
ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Supabase ---
# Ambil dari: https://app.supabase.com → Project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-super-secret-jwt-key-from-supabase-dashboard

# --- Database (PostgreSQL via Supabase) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# --- Google Gemini ---
GEMINI_API_KEY=AIzaSy...

# --- ChromaDB ---
CHROMA_PERSIST_DIRECTORY=./chroma_db

# --- Email SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=deskmate@epson.internal
